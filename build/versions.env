# Pinned upstream versions for the custom Fossil build. Each dependency is
# vendored as a git submodule under ../vendor/. Each ref below documents what
# is checked out in the corresponding submodule path.
#
# Update procedure:
#   cd vendor/<name> && git fetch && git checkout <new-ref> && cd ../..
#   git add vendor/<name>
#   # then bump the corresponding *_REF variable in this file
#   git commit -m "Bump <name> to <new-ref>"

# ── Fossil ────────────────────────────────────────────────────────
# Source: github.com/drhsqlite/fossil-mirror (submodule: vendor/fossil)
# Tag:    version-2.28 (latest stable at pinning)
# Released: 2026-03-11
FOSSIL_VERSION=2.28
FOSSIL_REF=1573b8e66e402f7d3f5cf70d37036a4ba2966edd
FOSSIL_NATIVE_HASH_PREFIX=52445a27
FOSSIL_RELEASED=2026-03-11

# Source-layout assumptions verified at this revision:
#   src/sqlite3.c, src/sqlite3.h  bundled SQLite amalgamation; we substitute
#                                 SQLCipher's at the SQLITE3_ORIGIN=1 path
#                                 (src/sqlite3-see.c) when --with-see=1
#   src/db.c                      where db_open and the existing SEE policy
#                                 hook live; target of fossil-db-key.patch
#   configure                     autosetup entry; flags verified in auto.def
#
# Verified configure flags (from auto.def):
#   --with-openssl=<path>
#   --with-see=1                  enables Fossil's SEE scaffolding; defines
#                                 USE_SEE and SQLITE_HAS_CODEC
#   --json
#   --internal-sqlite=1           default; we substitute the bundled amalgamation

# ── SQLCipher (LibreSSL-patched fork) ─────────────────────────────
# Source: github.com/wmacevoy/sqlcipher-libressl (submodule: vendor/sqlcipher-libressl)
# Branch: master at pin time
# Last commit subject: "Upgrade baseline to SQLCipher v4.16.0 (SQLite 3.53.1)"
# SQLite baseline: 3.53.1 (provides sqlite3_str_free, SQLITE_DBCONFIG_FP_DIGITS,
# SQLITE_LIMIT_PARSER_DEPTH — symbols Fossil 2.28 expects).
SQLCIPHER_LIBRESSL_REF=84ac318f44c75cf6aefb489441763a6ef6f7deee
SQLCIPHER_LIBRESSL_DATE=2026-06-06

# ── LibreSSL ──────────────────────────────────────────────────────
# Distributed as a release tarball from GitHub (the libressl/portable
# git tree is build glue around OpenBSD sources it doesn't carry; the
# release tarballs have everything pre-assembled and build with CMake).
# This is the same approach sqlcipher-libressl uses in CI.
# Matches sqlcipher-libressl CI's v4.2.1 pin.
LIBRESSL_VERSION=4.2.1
LIBRESSL_TARBALL_URL=https://github.com/libressl/portable/releases/download/v4.2.1/libressl-4.2.1.tar.gz
LIBRESSL_TARBALL_SHA256=6d5c2f58583588ea791f4c8645004071d00dfa554a5bf788a006ca1eb5abd70b

# ── QuickJS (CLI runtime; not linked into Fossil) ─────────────────
# Source: github.com/bellard/quickjs (submodule: vendor/quickjs)
# Branch: master at pin time (Bellard does not tag releases)
# Last commit subject: "new release"
QUICKJS_REF=3d5e064e9dd67c70f7962836505a7fa067bf0a4e
QUICKJS_DATE=2026-06-04
