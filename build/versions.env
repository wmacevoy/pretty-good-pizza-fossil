# Pinned upstream versions for the custom Fossil build.
# Sourced by build-fossil.sh. Each value can be overridden via the environment
# before invoking the script, but the recipe is reproducible only against the
# values pinned here.

# ── Fossil ───────────────────────────────────────────────────────
# Tag: version-2.28 (latest stable as of pinning).
# Released: 2026-03-11.
# Source: github.com/drhsqlite/fossil-mirror (the upstream Fossil project hosts
# its primary repo at fossil-scm.org; the GitHub mirror gives us a git-checkable
# commit SHA for build reproducibility).
# Verified 2026-06-06 via: gh api repos/drhsqlite/fossil-mirror/tags
FOSSIL_VERSION=2.28
FOSSIL_REF=1573b8e66e402f7d3f5cf70d37036a4ba2966edd
# Fossil-native commit hash (for verifiers cloning via fossil itself).
FOSSIL_NATIVE_HASH_PREFIX=52445a27
FOSSIL_RELEASED=2026-03-11

# Source-layout assumptions verified at this revision:
#   - src/sqlite3.c, src/sqlite3.h  (bundled SQLite amalgamation; we overwrite
#                                    with SQLCipher's amalgamation)
#   - src/db.c                      (where db_open lives; target of the
#                                    mode-aware PRAGMA key patch)
#   - configure                     (autosetup entry; flags verified in auto.def)
#
# Verified configure flags (from auto.def):
#   --with-openssl=<path>           (path|auto|tree|none)
#   --with-tcl=<path>               (path to Tcl install)
#   --with-tcl-stubs                (boolean)
#   --json                          (boolean; enables Fossil's JSON API)
#   --with-zlib=<path>              (path|auto|tree)
#   --internal-sqlite=1             (default; keep, since we substitute the
#                                    bundled amalgamation rather than linking
#                                    an external SQLite)
#   --with-see=1                    (existing scaffolding for SEE; may be
#                                    reusable by the SQLCipher patch — see
#                                    build/README.md)

# ── Remaining components (not yet pinned) ────────────────────────
# Pin these before the build is reproducible end-to-end.
#
# LIBRESSL_VERSION=4.2.1               # CI of sqlcipher-libressl uses 4.2.1
# SQLCIPHER_LIBRESSL_REF=<commit-sha>  # commit in sibling sqlcipher-libressl
# TCL_VERSION=8.6.NN                   # latest 8.6.x stable from tcl.tk
