#!/usr/bin/env tclsh
# Pretty Good Pizza voting CLI.
# Subcommands: init, vote, tally, verify.

namespace eval ::ppp {}

set ::ppp::root [file dirname [file dirname [file normalize [info script]]]]
source [file join $::ppp::root lib manifest.tcl]
source [file join $::ppp::root lib ballot.tcl]
source [file join $::ppp::root lib tally.tcl]

proc ::ppp::usage {} {
    puts stderr "usage: ppp <subcommand> \[args...\]"
    puts stderr ""
    puts stderr "  init <manifest.json>       Create election in current Fossil repo"
    puts stderr "  vote <option-id> ...       Cast a ballot approving the listed options"
    puts stderr "  tally                      Compute the result from synced ballots"
    puts stderr "  verify                     Re-run tally, compare to committed result"
    puts stderr "  help                       Show this message"
    exit 1
}

proc ::ppp::cmd_init {argv} {
    puts stderr "ppp init: not implemented (phase 1 stub)"
    puts stderr "  expected: validate manifest, write to repo root, fossil ci -m 'genesis: <election_id>'"
    exit 2
}

proc ::ppp::cmd_vote {argv} {
    puts stderr "ppp vote: not implemented (phase 1 stub)"
    puts stderr "  expected: read manifest.json, build ballot JSON from \$argv,"
    puts stderr "  write ballots/<fp>.json, fossil ci (clearsign attaches signature)"
    exit 2
}

proc ::ppp::cmd_tally {argv} {
    puts stderr "ppp tally: not implemented (phase 1 stub)"
    puts stderr "  expected: load manifest + all ballots, fetch/derive seed,"
    puts stderr "  run ::ppp::tally::run, write result.json, fossil ci"
    exit 2
}

proc ::ppp::cmd_verify {argv} {
    puts stderr "ppp verify: not implemented (phase 1 stub)"
    puts stderr "  expected: re-run tally from public inputs, compare to committed result,"
    puts stderr "  exit 0 on match"
    exit 2
}

if {[llength $argv] == 0} { ::ppp::usage }

set sub [lindex $argv 0]
set rest [lrange $argv 1 end]
switch -- $sub {
    init    { ::ppp::cmd_init $rest }
    vote    { ::ppp::cmd_vote $rest }
    tally   { ::ppp::cmd_tally $rest }
    verify  { ::ppp::cmd_verify $rest }
    help    -
    --help  -
    -h      { ::ppp::usage }
    default {
        puts stderr "unknown subcommand: $sub"
        ::ppp::usage
    }
}
